# --- GCP ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_SERVICE_ACCOUNT_JSON_PATH=./gcp-service-account.json

# Optional: only needed for LIVE cost data.
# Set up BigQuery Billing Export in GCP Console first:
# Billing > Billing export > BigQuery export > enable "Detailed usage cost"
# Then fill in the fully-qualified table, e.g. my-project.billing_export.gcp_billing_export_v1_XXXXXX
GCP_BILLING_BQ_TABLE=

# --- AWS (used in a later step) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Azure (used in a later step) ---
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=
